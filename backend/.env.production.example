# ===========================================
# CONFIGURATION UNTUK DEPLOYMENT VPS UBUNTU
# ===========================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-from-supabase
SUPABASE_SERVICE_KEY=your-service-role-key-from-supabase

# JWT Configuration - GENERATE BARU UNTUK PRODUCTION!
# Jalankan perintah ini untuk generate:
# python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=generate-new-secret-here

# CORS - Domain yang diizinkan akses API
# Pisahkan dengan koma untuk multiple origins
# Contoh: https://budgetapp.com,http://192.168.1.100:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
